{
  "expo": {
    "name": "Quimica- RA",
    "slug": "quimica-ra-kssoft",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.kssoft.quimica_ra"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "@reactvision/react-viro",
        {
          "cameraPermission": "This app needs access to camera to take photos of real world for AR",
          "microphonePermission": "This app needs access to microphone to record audio for AR"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "devClient": {
      "scheme": "myapp"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cb06550b-5b4c-418f-bb1d-af634f8b5d96"
      }
    }
  }
}
